{
  "name": "@dilithia/sdk-node",
  "version": "0.3.0",
  "type": "module",
  "description": "Node/TypeScript SDK for the Dilithia RPC, contracts, messaging, and sponsor surface.",
  "license": "MIT OR Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dilithia/languages-sdk.git"
  },
  "homepage": "https://github.com/dilithia/languages-sdk",
  "bugs": {
    "url": "https://github.com/dilithia/languages-sdk/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/sdk.test.mjs",
    "pack:local": "npm pack"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
